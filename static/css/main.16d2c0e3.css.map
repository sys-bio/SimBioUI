/* styles.css */
.panels-container {
  display: flex;
  height: 100vh;
  width: 100vw;
}

.left-subpanel {
  position: relative;
  resize: horizontal;
  padding: 10px;
  box-sizing: border-box;
  height: calc(100vh - 100px); /* Adjusted height to ensure visibility */
  overflow: auto;
  border-right: 1px solid gray; /* Add a right border with a color of your choice */
  border-top: 1px solid white;
  border-bottom: 1px solid gray; /* Add a bottom border */
  margin-top: 60px; /* Adjust the margin-top to move the sub-panel up */
  margin-bottom: 80px; /* Remove margin-bottom */
}

.resize-handle {
  background-color: #4d4d4d; /* Color of the resize handle */
  width: 5px; /* Width of the handle */
  height: 100%;
  cursor: ew-resize; /* Cursor indicates horizontal resizing */
  position: absolute;
  right: 0; /* Position the handle on the right edge of the panel */
  top: 0;
}
.resize-right-handle {
  background-color: #4d4d4d; /* Color of the resize handle */
  width: 5px; /* Width of the handle */
  height: 100%;
  cursor: ew-resize; /* Cursor indicates horizontal resizing */
  position: absolute;
  left: 0; /* Position the handle on the right edge of the right sub-panel */
  top: 0;
}

html, body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',
  'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',
  sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  overflow: hidden;
}

code {
  font-family: source-code-pro, Menlo, Monaco, Consolas, 'Courier New',
  monospace;
}

button {
  background-color: black; /* Change button background to black */
  color: white;           /* Change text color to white for contrast */
  border: none;
  padding: 4px 12px;
  text-align: center;
  text-decoration: none;
  display: inline-block;
  font-size: 10px;
  margin: 4px 2px;
  cursor: pointer;
  border-radius: 4px;
  height: 30px;
}

button:hover {
  background-color: #333333; /* Darker shade of black for hover effect */
}

.button-style {
  background-color: #242323; /* Background color */
  color: #fff; /* Text color */
  border: 1px solid gray; /* Add a white border */
  padding: 2px 11px; /* Padding inside the button */
  text-align: left; /* Center the text */
  text-decoration: none; /* No underline on text */
  display: inline-block; /* Button does not take full width */
  font-size: 10px; /* Font size */
  margin: 4px 2px; /* Margin around the button */
  cursor: pointer; /* Cursor appears as a pointer on hover */
  border-radius: 4px; /* Rounded corners */
  width: 95%; /* Set a specific width */
  height: 24px; /* Set a specific height */
}

.small-text {
  font-size: 12px;
  color: white;
  margin-top: 20px;
}

.text-simulation {
  font-size: 16px; /* Adjust the font size as needed */
  color: white; /* Change the text color to white */
  margin-left: 25px;
  margin-top: -30px;
}

.parameter-input-box {
  background-color: black;
  color: white;
  border: 1px solid gray; /* You can add a border for styling */
  padding: 10px; /* Add padding for spacing */
  font-size: 12px;
  outline: none;
  width: 25px;
  height: 2px; /* Adjust the height as needed */
  position: absolute;
  right: 10px;
  border-radius: 5px;
}

.simulate-style {
  background-color: royalblue;
  color: white;
  margin-left: 10px;
  margin-top: 15px;
  font-size: 12px;
  white-space: normal; /* Allows text to wrap */
  overflow: hidden; /* Prevents text from overflowing the button */
  text-overflow: ellipsis; /* Adds an ellipsis if the text overflows (optional) */
  word-wrap: break-word; /* Ensures words can be broken if needed to fit */
  width: auto; /* Adjusts width to content up to max width */
  max-width: 100%; /* Ensures button doesn't exceed its container */
  padding: 10px 25px; /* Adjust padding as needed */
  line-height: 1.2; /* Adjust line height to control spacing between wrapped lines */
}

.reset-style {
  background-color: black;
  color: white;
  margin-left: 10px;
  margin-top: 15px;
  font-size: 12px;
  white-space: normal; /* Allows text to wrap */
  overflow: hidden; /* Prevents text from overflowing the button */
  text-overflow: ellipsis; /* Adds an ellipsis if the text overflows (optional) */
  word-wrap: break-word; /* Ensures words can be broken if needed to fit */
  width: auto; /* Adjusts width to content up to max width */
  max-width: 100%; /* Ensures button doesn't exceed its container */
  padding: 10px 20px; /* Adjust padding as needed */
  line-height: 1.2; /* Adjust line height to control spacing between wrapped lines */
}
.text-checkbox-input {
  color: white;
  font-size: 12px;
  margin-top: 10px;
  margin-left: 8px;
}

.config-button {
  margin-left: 1%;
  font-size: 12px;
  border: 1px solid gray;

}

.icon-container img {
  width: 50px;  /* Adjust the width as needed */
  height: 50px; /* Adjust the height as needed */
}

.components-container-in-param-popup{
  position: absolute;
  left:55px;
  top: 30px;
}
.components-container-in-yaxis-popup {
  position: absolute;
  left: 70px;
  top: 120px;
  width: 250px;
  height: 300px;
}
.axis-icon {
  margin-top: 10px;
  margin-left: 0px;
}





