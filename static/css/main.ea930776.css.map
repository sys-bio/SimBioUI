.custom-scrollbars__container {
    position: relative;
    width: 100%;
    height: 100%;
}

.custom-scrollbars__content {
    width: 100%;
    height: 100%;
    overflow: hidden; /* Hide the default scrollbar */
}

.custom-scrollbars__scrollbar {
    position: absolute;
    top: 0;
    right: 0; /* Align scrollbar to the right */
    width: 10px; /* Width of the scrollbar */
    height: 100%; /* Full height of the container */
}

.custom-scrollbars__track-and-thumb {
    position: relative;
    width: 100%;
    height: 100%;
}

.custom-scrollbars__track {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    background-color: #ccc; /* Color of the track */
    border-radius: 5px;
}

.custom-scrollbars__thumb {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    background-color: #888; /* Color of the thumb */
    border-radius: 5px;
    cursor: grab;
}